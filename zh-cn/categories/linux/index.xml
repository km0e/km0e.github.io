&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> address 10.1.0.1
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> netmask 255.255.0.0
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> bridge_ports enp3s0 enp4s0 enp5s0
